# =============================================================================
# Example environment file — copy to `.env` and replace dummy values.
#
#   cp .env.example .env
#
# The app loads `.env` from the project root (via godotenv). `.env` is
# gitignored; never commit real secrets. For CI/CD, use GitHub Actions secrets
# and variables instead of this file.
#
# Reference: README → “Configuration file (.env)” and “Environment Variables”.
# =============================================================================

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Connection string and logical database name used by the API.

MONGO_URI=mongodb://localhost:27017
MONGO_DB=userservice

# ── JWT ─────────────────────────────────────────────────────────────────────
# Signing secret for access (Bearer) JWTs. In production/prod, must be ≥ 32 characters
# and MUST NOT be the placeholder below.
#
# Access tokens are short-lived. Refresh tokens are opaque, stored hashed in MongoDB,
# and rotate on each POST /auth/refresh.
#
# JWT_ACCESS_EXPIRE_MINUTES — access JWT lifetime (default 15 if unset and JWT_EXPIRE_HOURS unset).
# JWT_EXPIRE_HOURS — if set without JWT_ACCESS_EXPIRE_MINUTES, access TTL = hours × 60 (capped).
# JWT_REFRESH_EXPIRE_HOURS — refresh token TTL in hours (default 720).

JWT_SECRET=dummy-dev-only-secret-replace-in-real-deploys-32chars
JWT_EXPIRE_HOURS=24
# JWT_ACCESS_EXPIRE_MINUTES=15
# JWT_REFRESH_EXPIRE_HOURS=720

# ── HTTP / TLS ports ────────────────────────────────────────────────────────
# PORT: plain HTTP (e.g. ECS behind ALB, or docker-compose prod).
# TLS_PORT: HTTPS when the Go binary terminates TLS (local dev, test compose).

PORT=8080
TLS_PORT=8443

# ── Runtime profile ─────────────────────────────────────────────────────────
# development | test | production  (CDK/ECS may use prod)
# production/prod enforces strong JWT_SECRET and stricter JWT_EXPIRE_HOURS.

ENV=development

# ── Observability ───────────────────────────────────────────────────────────
# Structured logs (slog): each request logs http_request with request_id, and user_id when authenticated.
# Send or reuse X-Request-ID; the API echoes it on the response.
# LOG_JSON defaults to true in production/prod; in development defaults to false (human-readable text).
# LOG_LEVEL: debug | info | warn | error
#
# Prometheus metrics at GET /metrics (namespace gomicro_http_*). Scrape from your network/VPC; disable
# with METRICS_ENABLED=false if you do not want the endpoint or per-request metric recording.

# LOG_LEVEL=info
# LOG_JSON=false
# METRICS_ENABLED=true

# ── TLS file paths (optional locally) ───────────────────────────────────────
# Leave empty in dev/test: certs auto-generate under ./certs/
# Production behind Nginx/Let’s Encrypt: set paths after certbot, e.g.:
#   TLS_CERT=/etc/letsencrypt/live/api.example.com/fullchain.pem
#   TLS_KEY=/etc/letsencrypt/live/api.example.com/privkey.pem

TLS_CERT=
TLS_KEY=

# ── CORS (browser SPA) ───────────────────────────────────────────────────────
# Comma-separated Origin values (scheme://host:port) allowed to call the API from a browser.
# In development/test, if unset, defaults include Vite dev (5173) and preview (4173).
# In production/prod, set explicitly, e.g. https://app.example.com

# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173

# ── Password reset & email (optional in dev; required for forgot-password in production) ─
# SPA page where the reset link should open (query param ?token=... is appended).
# Defaults in development/test to http://localhost:5173/reset-password when unset.
# PASSWORD_RESET_FRONTEND_URL=https://app.example.com/reset-password
# PASSWORD_RESET_TOKEN_MINUTES=60

# SMTP — when SMTP_HOST is set, the API sends real reset emails. In production/prod,
# forgot-password returns 503 until SMTP_HOST, SMTP_FROM, and PASSWORD_RESET_FRONTEND_URL are set.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# ── Email verification after register (optional) ────────────────────────────
# Default off. Set EMAIL_VERIFICATION_REQUIRED=true to require verifying email before login.
# Uses the same SMTP settings as password reset. In production, EMAIL_VERIFICATION_FRONTEND_URL is required.
# Dev default for the link target: http://localhost:5173/verify-email
#
# EMAIL_VERIFICATION_REQUIRED=false
# EMAIL_VERIFICATION_FRONTEND_URL=https://app.example.com/verify-email
# EMAIL_VERIFICATION_TOKEN_MINUTES=1440

# ── Email change (PUT /users/:id with new email) ─────────────────────────────
# Stages the new address in pending_email and emails a link to confirm. Login email stays until POST /auth/confirm-email-change.
# In production, set EMAIL_CHANGE_FRONTEND_URL and SMTP (same as password reset). Dev default: http://localhost:5173/confirm-email-change
#
# EMAIL_CHANGE_FRONTEND_URL=https://app.example.com/confirm-email-change
# EMAIL_CHANGE_TOKEN_MINUTES=1440

# ── Abuse / safety (optional) ───────────────────────────────────────────────
# Cloudflare Turnstile: when TURNSTILE_SECRET_KEY is set, POST /auth/register and /auth/login
# require JSON field "turnstile_token" from the widget. Frontend: set VITE_TURNSTILE_SITE_KEY (see Cloudflare dashboard).
# Dummy keys that always pass (for local testing): search Cloudflare Turnstile test keys.
#
# TURNSTILE_SECRET_KEY=
#
# Per-account lockout after wrong passwords (Mongo users.failed_login_attempts / locked_until).
# Set LOGIN_LOCKOUT_MAX_ATTEMPTS=0 to disable. LOGIN_LOCKOUT_MINUTES: how long the lock lasts after threshold.
#
# LOGIN_LOCKOUT_MAX_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15

# ── LISTEN_HTTP (optional) ──────────────────────────────────────────────────
# If true/1/yes: serve plain HTTP on PORT only (TLS at reverse proxy / ALB).
# Unset for local HTTPS on TLS_PORT.

# LISTEN_HTTP=false

# ── Public DNS apex (optional) ──────────────────────────────────────────────
# No scheme, no path — e.g. example.com
# Used by: `make route53-alias` (DNS_ZONE defaults to DOMAIN).
# For GitHub Actions hostnames (dev-api.<DOMAIN>, …), set repo Variable DOMAIN.

DOMAIN=example.com
