# =============================================================================
# Example environment file — copy to `.env` and replace dummy values.
#
#   cp .env.example .env
#
# The app loads `.env` from the project root (via godotenv). `.env` is
# gitignored; never commit real secrets. For CI/CD, use GitHub Actions secrets
# and variables instead of this file.
#
# Reference: README → “Configuration file (.env)” and “Environment Variables”.
# =============================================================================

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Connection string and logical database name used by the API.

MONGO_URI=mongodb://localhost:27017
MONGO_DB=userservice

# ── JWT ─────────────────────────────────────────────────────────────────────
# Signing secret for access tokens. In production/prod, must be ≥ 32 characters
# and MUST NOT be the placeholder below.

JWT_SECRET=dummy-dev-only-secret-replace-in-real-deploys-32chars
JWT_EXPIRE_HOURS=24

# ── HTTP / TLS ports ────────────────────────────────────────────────────────
# PORT: plain HTTP (e.g. ECS behind ALB, or docker-compose prod).
# TLS_PORT: HTTPS when the Go binary terminates TLS (local dev, test compose).

PORT=8080
TLS_PORT=8443

# ── Runtime profile ─────────────────────────────────────────────────────────
# development | test | production  (CDK/ECS may use prod)
# production/prod enforces strong JWT_SECRET and stricter JWT_EXPIRE_HOURS.

ENV=development

# ── TLS file paths (optional locally) ───────────────────────────────────────
# Leave empty in dev/test: certs auto-generate under ./certs/
# Production behind Nginx/Let’s Encrypt: set paths after certbot, e.g.:
#   TLS_CERT=/etc/letsencrypt/live/api.example.com/fullchain.pem
#   TLS_KEY=/etc/letsencrypt/live/api.example.com/privkey.pem

TLS_CERT=
TLS_KEY=

# ── CORS (browser SPA) ───────────────────────────────────────────────────────
# Comma-separated Origin values (scheme://host:port) allowed to call the API from a browser.
# In development/test, if unset, defaults include Vite dev (5173) and preview (4173).
# In production/prod, set explicitly, e.g. https://app.example.com

# CORS_ALLOWED_ORIGINS=https://app.example.com,http://localhost:5173

# ── Password reset & email (optional in dev; required for forgot-password in production) ─
# SPA page where the reset link should open (query param ?token=... is appended).
# Defaults in development/test to http://localhost:5173/reset-password when unset.
# PASSWORD_RESET_FRONTEND_URL=https://app.example.com/reset-password
# PASSWORD_RESET_TOKEN_MINUTES=60

# SMTP — when SMTP_HOST is set, the API sends real reset emails. In production/prod,
# forgot-password returns 503 until SMTP_HOST, SMTP_FROM, and PASSWORD_RESET_FRONTEND_URL are set.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com

# ── LISTEN_HTTP (optional) ──────────────────────────────────────────────────
# If true/1/yes: serve plain HTTP on PORT only (TLS at reverse proxy / ALB).
# Unset for local HTTPS on TLS_PORT.

# LISTEN_HTTP=false

# ── Public DNS apex (optional) ──────────────────────────────────────────────
# No scheme, no path — e.g. example.com
# Used by: `make route53-alias` (DNS_ZONE defaults to DOMAIN).
# For GitHub Actions hostnames (dev-api.<DOMAIN>, …), set repo Variable DOMAIN.

DOMAIN=example.com
