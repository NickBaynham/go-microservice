# Vite env vars must be prefixed with VITE_ to be exposed to the client.
# Copy to .env.local for local dev (gitignored by Vite patterns — use .env.local).

# Base URL of the Go API (no trailing slash). Examples:
#   http://localhost:8080
#   http://127.0.0.1:18080
#   https://api.example.com

VITE_API_BASE_URL=http://localhost:8080
