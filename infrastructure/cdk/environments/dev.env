# Dev environment configuration
# Source this file before running cdk commands locally:
#   source environments/dev.env && cdk deploy
#
# In GitHub Actions these are set as environment variables in the job.

CDK_ENV=dev
CDK_REGION=us-east-1
CDK_DESIRED_COUNT=1
CDK_TASK_CPU=256
CDK_TASK_MEMORY=512

# Set these for your account (or export from CI secrets):
# export CDK_ACCOUNT=123456789012
# export CDK_APP_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/go-microservice:abc1234
# export CDK_CERT_ARN=arn:aws:acm:us-east-1:123456789012:certificate/...
# export CDK_JWT_SECRET=<your-secret>   ← never commit this